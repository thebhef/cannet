{
  "version": "2.0.0",
  "tasks": [
    {
      // Backgrounded Vite dev server. The launch.json "Debug cannet-gui
      // (dev, with Vite)" config waits for Vite to print "ready in" before
      // launching the Rust host so the WebView has a server to connect to.
      "label": "vite:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "apps/gui", "dev"],
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": [
          {
            "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
            "file": 1,
            "location": 2,
            "severity": 3,
            "code": 4,
            "message": 5
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*ready in.*"
        }
      }
    },
    {
      // One-shot frontend build for the release-bundle debug config so
      // the Tauri host has a `apps/gui/dist/` to embed.
      "label": "frontend:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "apps/gui", "build"],
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      }
    }
  ]
}
